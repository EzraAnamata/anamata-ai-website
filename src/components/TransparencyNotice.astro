---
/**
 * Art. 50 transparency notice — mandatory on every page (EU AI Act DoD).
 * Full variant in the home hero; condensed variant in subpage footers.
 * Styled as a stamped marginal note: brand voice, not fine print.
 */
interface Props {
  condensed?: boolean;
}
const { condensed = false } = Astro.props;
---

<aside class:list={['notice', { condensed }]} aria-label="AI transparency notice">
  <span class="glyph mono">§50</span>
  <p>
    <span class="nk">TRANSPARENCY NOTICE — EU AI ACT, ART. 50</span>
    Content on this site is produced by AI systems and reviewed by a named human editor before
    publication.{' '}
    <a href="/about#ledger">Every change is on the record.</a>
  </p>
</aside>
