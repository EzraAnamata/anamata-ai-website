---
/**
 * Home — THE funnel, as a film (SPEC-website-v2-ia-choreography).
 * The scroll is the funnel; ledger grammar (marginalia numbers, rules, stamps)
 * makes descending the page feel like paging through a record.
 *
 * S8 (#368, Peter 2026-07-21): the homepage is the "what". The HOW/autonomy
 * section and the live operating record moved to /about; home is now hero →
 * what → exit.
 *
 *   0    HERO     — Anna resolving wireframe→human on scroll (AnnaScrub)
 *   H001 WHAT     — concrete jobs as DEMO ledger entries: employee question →
 *                   Anna's logged action (S9, spec §1.2), labeled as examples
 *   H002 FITS     — works-in-your-landscape strip: Teams today + koppelbaar
 *                   connections, technical depth on /about (S9, spec §1.4)
 *   H003 EXIT     — configurator teaser → quote (shared CtaBlock: coral primary,
 *                   demo ghost, "want to know more?" → About)
 *   H004 MEET     — Meet-Anna form (S10a §1.5): the early-phase funnel path, a
 *                   short-intro ask via the SHARED RequestForm. Its submit is
 *                   secondary (ghost) so home keeps exactly one coral (§1.6).
 *                   Numbering is gapless as-built; rebased on S9's FITS strip,
 *                   the order is WHAT/FITS/EXIT/MEET → H001/H002/H003/H004.
 *
 * Non-negotiables: tokens are law; the ledger is never fabricated (scene 001's
 * entries are visibly labeled examples); no prices; §50 transparency present.
 */
import Base from '../layouts/Base.astro';
import AnnaScrub from '../components/AnnaScrub.astro';
import TransparencyNotice from '../components/TransparencyNotice.astro';
import CtaBlock from '../components/CtaBlock.astro';
import RequestForm from '../components/RequestForm.astro';
import { MODULES } from '../lib/offerte.mjs';

// The Meet-Anna form files to the same channel as /contact (§1.5): info@ only.
const CONTACT_EMAIL = 'info@anamata.ai';
---

<Base
  title="Anna — your digital AI assistant, working in Teams today | Anamata.ai"
  description="Anna is Anamata's AI colleague: she handles answers, requests and admin inside Microsoft Teams, bounded by permission rings and a human approval gate. See her work, then see the real operating record of the AI team that runs this site."
  condensedNotice={false}
  preloadImage="/anna/anna-split-face.webp"
>
  <!-- ============ 0 · HERO (Anna scrub) ============ -->
  <!-- tagline wording is an open trio brainstorm — placeholder, easily edited here -->
  <AnnaScrub
    kicker="ANAMATA.AI — EMPLOYEE #001"
    heading="Anna, your digital AI assistant"
    subline="Answers, requests and admin — the work around the work — handled inside your company systems, in Teams, today."
  />

  <!-- ============ 001 · WHAT ANNA DOES ============ -->
  <div class="sheet first-scene">
    <aside class="marginalia">
      <span class="no">H001</span>
      <span class="lbl">WHAT ANNA<br />DOES</span>
      <span class="lbl push">RECORD<br />H001</span>
    </aside>
    <main class="content">
      <span class="kicker">Record H001 · What she does</span>
      <h2 class="sec-title">The work no human should waste time on.</h2>
      <p class="sec-intro">
        Picture the office manager at any mid-sized company — drowning in systems. This is the work
        around the work, and no one should spend a day on it. Someone asks; Anna does it where the
        team already works, and writes down what she did. A day in Teams looks like this.
      </p>

      <div class="demo-ledger" aria-label="Illustrative examples — not the live operating record">
        <div class="demo-head">
          <span class="t">EXAMPLE — A DAY IN TEAMS</span>
          <span class="t warn">DEMO · NOT THE LIVE RECORD</span>
        </div>
        <div class="demo-entry">
          <span class="ts">09:12</span>
          <span class="ask mono">“Can you sort my hours?”</span>
          <span class="act">logged 3.5h to ClockWise — “sprint review” <span class="agent">· anna</span></span>
          <span class="tag">EXAMPLE</span>
        </div>
        <div class="demo-entry">
          <span class="ts">09:41</span>
          <span class="ask mono">“Can you file my leave?”</span>
          <span class="act">filed a vacation request for approval — 12–16 Aug <span class="agent">· anna</span></span>
          <span class="tag">EXAMPLE</span>
        </div>
        <div class="demo-entry">
          <span class="ts">10:03</span>
          <span class="ask mono">“Can you book me a desk?”</span>
          <span class="act">booked a desk — Utrecht, Thu, near the QA pod <span class="agent">· anna</span></span>
          <span class="tag">EXAMPLE</span>
        </div>
        <div class="demo-entry">
          <span class="ts">10:20</span>
          <span class="ask mono">“Where's the onboarding procedure?”</span>
          <span class="act">answered from company systems <span class="agent">· anna</span></span>
          <span class="tag">EXAMPLE</span>
        </div>
      </div>
      <p class="demo-foot mono">
        Illustrative examples, not the operating record. The live, unedited record — how this site
        itself is built and run — is <a href="/about#ledger">on the record, over on About</a>.
      </p>

      <!-- Early-phase funnel entry (§1.6): ghost, never coral — home's one coral
           is the CtaBlock quote until S10b. Jumps to the Meet-Anna form (H004). -->
      <div class="cta-row">
        <a class="btn ghost" href="#meet-anna">Explore Anna for your team →</a>
      </div>
    </main>
  </div>

  <!-- ============ 002 · FITS YOUR LANDSCAPE ============ -->
  <!-- S9 (spec §1.4, #377 reduced): home is the "what", and "she works in what
       you already run" IS the what. One compact strip, not a section of cards —
       Teams today (no Slack, overruled — Peter §2), koppelbaar connections in
       plain English (never the word "MCP"), technical depth one click away on
       /about (the HOW lives there). A slot for the E2E storyboard (#376) will
       later insert here as H002 and renumber the sheets below in one PR. -->
  <div class="sheet">
    <aside class="marginalia">
      <span class="no">H002</span>
      <span class="lbl">FITS YOUR<br />LANDSCAPE</span>
      <span class="lbl push">RECORD<br />H002</span>
    </aside>
    <section class="content" aria-label="Fits your landscape">
      <span class="kicker">Record H002 · Fits your landscape</span>
      <h2 class="sec-title">She works in what you already run.</h2>
      <p class="sec-intro">
        No migration, no new app to adopt. Anna joins the team in the channel it already uses and
        connects to the systems you already run — so the work lands back where people expect it.
      </p>

      <dl class="fits-strip">
        <div class="fits-row">
          <dt class="fits-k">Channel</dt>
          <dd class="fits-v">
            <strong>Microsoft Teams</strong> — today. She works where the conversation already
            happens.
            <span class="fits-note">A mobile app is an intention on the roadmap, not a promise yet.</span>
          </dd>
        </div>
        <div class="fits-row">
          <dt class="fits-k">Connections</dt>
          <dd class="fits-v">
            Connectable to the tools you already run — <strong>ClockWise</strong>,
            <strong>Loket</strong>, <strong>Remote</strong>, and more added as you need them.
            <span class="fits-note">
              How the connections work — and how they stay bounded — is
              <a href="/about">on the record, over on About</a>.
            </span>
          </dd>
        </div>
      </dl>
    </section>
  </div>

  <!-- ============ 003 · EXIT: BUILD YOUR ANNA ============ -->
  <!-- Home is the "what" (Peter, 2026-07-21): the HOW/autonomy section and the
       live operating record moved to /about. The exit (configure → quote)
       stays as the funnel's close. -->
  <div class="sheet">
    <aside class="marginalia">
      <span class="no">H003</span>
      <span class="lbl">BUILD<br />YOUR ANNA</span>
      <span class="lbl push">RECORD<br />H003</span>
    </aside>
    <section class="content" aria-label="Build your Anna">
      <span class="kicker">Record H003 · Build your Anna</span>
      <h2 class="sec-title">Configure the team you want.</h2>
      <p class="sec-intro">
        Pick the modules that fit, and file a quote request — a person reads it and comes back
        with a proposal on your terms. Phased rollout, no numbers here: you configure, we quote.
      </p>

      <div class="teaser-cards">
        {MODULES.map((m) => (
          <article class="teaser-card">
            <span class="teaser-stamp" aria-hidden="true"></span>
            <span class="kicker">{m.kicker}</span>
            <h3>{m.name}</h3>
            <p class="teaser-spec">{m.spec}</p>
          </article>
        ))}
      </div>

      <!-- Standard funnel exit — shared CtaBlock (S8 CTA consistency). The
           "want to know more?" referral routes the not-yet-ready to /about,
           where the HOW/proof now live (Peter, funnel-tied referral). -->
      <CtaBlock more="about" />
      <!-- The techie "tech@anamata.ai" hook lives once, in the footer's Row A on
           every page (Base.astro) — not repeated here, where it sat directly
           above its footer twin at the page bottom (S6 dedupe). -->
    </section>
  </div>

  <!-- ============ 004 · MEET ANNA (§1.5 — Meet-Anna form) ============ -->
  <!-- The early-phase funnel path (§1.6): most visitors aren't ready to buy, so
       the cheap ask is a short intro call. Uses the SHARED RequestForm (one
       implementation with /contact, extracted in S10a step 0) with a secondary
       (ghost) submit — a visitor already in the form needs no coral pull, and
       home's one coral is the CtaBlock quote (§1.6). Files to info@ via the
       existing mailto handler; no confirmation ledger here (the live-record
       grammar stays on /about). -->
  <div class="sheet" id="meet-anna">
    <aside class="marginalia">
      <span class="no">H004</span>
      <span class="lbl">MEET<br />ANNA</span>
      <span class="lbl push">RECORD<br />H004</span>
    </aside>
    <section class="content" aria-label="Meet Anna">
      <span class="kicker">Record H004 · Meet Anna</span>
      <h2 class="sec-title">Meet Anna</h2>
      <p class="sec-intro">
        Book a short introduction and explore what Anna could take off your team's hands.
      </p>

      <RequestForm CONTACT_EMAIL={CONTACT_EMAIL} submit="secondary" showConfirmation={false} />

      <!-- §50 notice: home carries the full transparency notice at the page end
           (the ledger it used to sit beside now lives on /about). -->
      <TransparencyNotice />
    </section>
  </div>
</Base>
