---
/**
 * Base layout: header, persistent record strip, footer, Art. 50 notice
 * (condensed footer variant on subpages — the full notice sits in the home
 * hero), fonts, global styles and the single load choreography moment.
 */
import '@fontsource/poppins/200.css';
import '@fontsource/poppins/400.css';
import '@fontsource/poppins/400-italic.css';
import '@fontsource/poppins/600.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '../styles/tokens.generated.css';
import '../styles/global.css';
import TransparencyNotice from '../components/TransparencyNotice.astro';
import { getLastAction } from '../lib/ledger.mjs';
// preload the three critical font files (design-brief typography note):
// Poppins 200 (hero display), Poppins 400 (body), IBM Plex Mono 400 (record).
import poppinsDisplayUrl from '@fontsource/poppins/files/poppins-latin-200-normal.woff2?url';
import poppinsBodyUrl from '@fontsource/poppins/files/poppins-latin-400-normal.woff2?url';
import plexMonoUrl from '@fontsource/ibm-plex-mono/files/ibm-plex-mono-latin-400-normal.woff2?url';

interface Props {
  title: string;
  description: string;
  /** home carries the full hero notice; subpages get the condensed footer variant */
  condensedNotice?: boolean;
  /** LCP image to preload (home only — the Anna portrait is the LCP element there) */
  preloadImage?: string;
}
const { title, description, condensedNotice = true, preloadImage } = Astro.props;
const lastAction = getLastAction();
const { pathname } = Astro.url;
// Absolute URLs for social/canonical (Astro.site = https://anamata.ai). The OG
// card is the committed, metadata-stripped split-face composite (scripts/
// build-og-image.mjs) — the one sanctioned figurative image, never Higgsfield.
const canonical = new URL(pathname, Astro.site);
const ogImage = new URL('/og-image.png', Astro.site);
const current = (p: string) =>
  (p === '/' ? pathname === '/' : pathname.startsWith(p)) ? 'page' : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="ai-generated"
      content="true; developed and operated by AI systems under named human editorial review — EU AI Act Art. 50"
    />
    <link rel="preload" as="font" type="font/woff2" href={poppinsDisplayUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={poppinsBodyUrl} crossorigin />
    <link rel="preload" as="font" type="font/woff2" href={plexMonoUrl} crossorigin />
    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph / social card (default og:image is the split-face composite;
         title/description/url are per-page, image is absolute per the spec). -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Anamata.ai" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Anna — Anamata's AI colleague, resolving from wireframe to human" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body>
    <header class="site-header">
      <a class="wordmark" href="/" aria-label="Anamata.ai — home">
        <img src="/anamata-ai-logo.svg" alt="Anamata.ai" width="149" height="32" />
      </a>
      <nav aria-label="Main">
        <a href="/about#team">The team</a>
        <a href="/about" aria-current={current('/about')}>About</a>
        <a href="/insights" aria-current={current('/insights')}>Insights</a>
        <a class="btn" href="/configurator">REQUEST A QUOTE</a>
      </nav>
    </header>

    <slot />

    <footer class="site-footer">
      <div class="inner">
        {condensedNotice && <TransparencyNotice condensed />}
        <div class="cols">
          <nav aria-label="Footer">
            <a href="/about">ABOUT</a>
            <a href="/insights">INSIGHTS</a>
            <a href="/contact">FILE A REQUEST</a>
            <a href="https://github.com/EzraAnamata/anamata-ai-website" rel="noopener">READ THE SOURCE ↗</a>
            <a href="https://anamata.eu" rel="noopener">ANAMATA.EU ↗</a>
          </nav>
          <p class="colophon tech-line">
            DRAWN HERE BY HOW THIS SITE RUNS? <a href="mailto:tech@anamata.ai">tech@anamata.ai</a>
          </p>
        </div>
        <p class="colophon site-colophon">ANAMATA BV · UTRECHT, NL · THE SITE IS ITS OWN EVIDENCE</p>
      </div>
    </footer>

    <div class="record-strip" role="status" aria-label="Operating record — last action">
      <span class="tag">LAST ACTION</span>
      <span>{lastAction}</span>
      <span class="ok">✓ ON RECORD</span>
    </div>

    <script>
      // The one choreographed moment (design-tokens animations.choreography).
      // Reduced motion: show final state.
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const entries = document.querySelectorAll('.ledger .entry');
      const bars = document.querySelectorAll('.bar');
      if (reduced) {
        entries.forEach((e) => e.classList.add('on'));
        bars.forEach((b) => b.classList.add('on'));
      } else {
        entries.forEach((e, i) => setTimeout(() => e.classList.add('on'), 500 + i * 650));
        setTimeout(() => bars.forEach((b) => b.classList.add('on')), 700);
      }
    </script>
  </body>
</html>
